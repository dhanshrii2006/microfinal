PORT=5000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/acadify

# JWT – change this to a long random string in production
JWT_SECRET=acadify_dev_secret_key_change_in_production_2026
JWT_EXPIRES_IN=7d

# Cookie
COOKIE_SECRET=acadify_cookie_secret_key_change_in_production_2026

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
